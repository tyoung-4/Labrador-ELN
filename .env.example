# PostgreSQL (default)
DATABASE_URL="postgresql://eln:elnpassword@localhost:5432/eln"

# Environment label — controls sandbox banner and dev badge in the UI
# Set to 'staging' on Railway staging to show amber warning banner
# Set to 'production' on Railway production to hide all badges
# Leave as 'development' or unset locally to show subtle DEV badge
NEXT_PUBLIC_ENV_LABEL=development   # set to 'staging' on Railway staging, 'production' on Railway production
