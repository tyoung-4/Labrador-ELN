generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  role         String        @default("MEMBER")
  createdAt    DateTime      @default(now())
  entries      Entry[]
  protocolRuns ProtocolRun[]
}

enum EntryType {
  GENERAL
  EXPERIMENT
  PROTOCOL
  NOTE
  CELL_LINE
  PROTEIN
  REAGENT
  CHROMATOGRAPHY_RUN
}

model Entry {
  id           String        @id @default(uuid())
  title        String
  description  String        @default("")
  technique    String        @default("General")
  entryType    EntryType     @default(GENERAL)
  typedData    Json          @default("{}")
  body         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  version      Int           @default(1)
  author       User?         @relation(fields: [authorId], references: [id])
  authorId     String?
  tags          Tag[]          @relation("EntryTags")
  attachments   Attachment[]
  protocolRuns  ProtocolRun[]  @relation("RunSource")
  linkedRun     ProtocolRun?   @relation("RunLink", fields: [linkedRunId], references: [id])
  linkedRunId   String?
}

model Attachment {
  id        String   @id @default(uuid())
  entry     Entry    @relation(fields: [entryId], references: [id])
  entryId   String
  filename  String
  mime      String
  size      Int
  path      String
  checksum  String?
  createdAt DateTime @default(now())
}

model Tag {
  id      String  @id @default(uuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model ProtocolRun {
  id               String   @id @default(uuid())
  title            String
  status           String   @default("IN_PROGRESS")
  locked           Boolean  @default(true)
  runBody          String
  notes            String   @default("")
  interactionState String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  sourceEntry    Entry     @relation("RunSource", fields: [sourceEntryId], references: [id])
  sourceEntryId  String
  runner         User?     @relation(fields: [runnerId], references: [id])
  runnerId       String?
  linkedEntries  Entry[]   @relation("RunLink")
}

model TodoHistory {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  date      String   // YYYY-MM-DD — the day the list belonged to
  items     Json     // TodoItem[] snapshot at time of cleanup
  createdAt DateTime @default(now())
}
