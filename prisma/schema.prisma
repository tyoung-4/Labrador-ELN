generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  role         String        @default("MEMBER")
  createdAt    DateTime      @default(now())
  entries      Entry[]
  protocolRuns ProtocolRun[]
}

model Entry {
  id           String        @id @default(uuid())
  title        String
  description  String        @default("")
  technique    String        @default("General")
  body         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  version      Int           @default(1)
  author       User?         @relation(fields: [authorId], references: [id])
  authorId     String?
  tags         Tag[]         @relation("EntryTags")
  attachments  Attachment[]
  protocolRuns ProtocolRun[]
  protocol     Protocol?
}

model Attachment {
  id        String   @id @default(uuid())
  entry     Entry    @relation(fields: [entryId], references: [id])
  entryId   String
  filename  String
  mime      String
  size      Int
  path      String
  checksum  String?
  createdAt DateTime @default(now())
}

model Tag {
  id      String  @id @default(uuid())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model ProtocolRun {
  id               String   @id @default(uuid())
  title            String
  status           String   @default("IN_PROGRESS")
  locked           Boolean  @default(true)
  runBody          String
  notes            String   @default("")
  interactionState String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  sourceEntry      Entry    @relation(fields: [sourceEntryId], references: [id])
  sourceEntryId    String
  runner           User?    @relation(fields: [runnerId], references: [id])
  runnerId         String?
}

model Protocol {
  id        String   @id @default(uuid())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections ProtocolSection[]
}

model ProtocolSection {
  id         String   @id @default(uuid())
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  protocolId String
  name       String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  steps ProtocolStep[]

  @@index([protocolId, order])
}

model ProtocolStep {
  id         String          @id @default(uuid())
  section    ProtocolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId  String
  stepType   StepType        @default(STEP)
  parentStep ProtocolStep?   @relation("ProtocolStepToSubsteps", fields: [parentStepId], references: [id], onDelete: Cascade)
  parentStepId String?
  substeps   ProtocolStep[]  @relation("ProtocolStepToSubsteps")
  estimatedMinutes Int?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([sectionId])
  @@index([parentStepId])
}

enum StepType {
  STEP
  SUBSTEP
}
