generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  name               String?
  role               String               @default("MEMBER")
  createdAt          DateTime             @default(now())
  // Auth — additive; null passwordHash means "no local password set yet"
  passwordHash       String?
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  sessions           Session[]
  entries            Entry[]
  protocolRuns       ProtocolRun[]
  projectMemberships ProjectMember[]
  recipes            Recipe[]
  uploadedFiles      RunStepFile[]
  fileAnnotations    FileAnnotation[]
  expressionRuns     ExpressionTimeline[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Tamper-evident audit trail. `hash = sha256(prevHash + payload)` chains rows
// per entity, so altering/removing a past row is detectable.
model AuditLog {
  id         String   @id @default(cuid())
  entityType String // "RUN" | "ENTRY" | "PROTEIN_BATCH" | ...
  entityId   String
  action     String // CREATE | UPDATE | DELETE | STATUS_CHANGE | SIGN | LOCK | UNLOCK
  actorId    String
  actorName  String
  summary    String   @default("")
  diff       Json?
  prevHash   String?
  hash       String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// Electronic signatures (attestations) attached to a record.
model Signature {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  signerId    String
  signerName  String
  meaning     String // COMPLETION | REVIEW | WITNESS
  statement   String
  contentHash String // hash of the record snapshot at signing time
  signedAt    DateTime @default(now())

  @@index([entityType, entityId])
}

enum EntryType {
  GENERAL
  EXPERIMENT
  PROTOCOL
  NOTE
  CELL_LINE
  PROTEIN
  REAGENT
  CHROMATOGRAPHY_RUN
}

model Entry {
  id                 String                  @id @default(uuid())
  title              String
  description        String                  @default("")
  technique          String                  @default("General")
  entryType          EntryType               @default(GENERAL)
  typedData          Json                    @default("{}")
  body               String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  version            Int                     @default(1)
  allowNonSequential Boolean                 @default(false)
  requireStepOrder   Boolean                 @default(false)
  status             String                  @default("PUBLISHED") // "DRAFT" | "PUBLISHED"
  publishedAt        DateTime?
  changeSummary      String                  @default("")
  draftOfId          String?
  draftOf            Entry?                  @relation("DraftOf", fields: [draftOfId], references: [id])
  drafts             Entry[]                 @relation("DraftOf")
  author             User?                   @relation(fields: [authorId], references: [id])
  authorId           String?
  attachments        Attachment[]
  protocolRuns       ProtocolRun[]           @relation("RunSource")
  linkedRun          ProtocolRun?            @relation("RunLink", fields: [linkedRunId], references: [id])
  linkedRunId        String?
  protocol           Protocol?
  inventoryLinks     ProtocolInventoryLink[]
}

model Attachment {
  id        String   @id @default(uuid())
  entry     Entry    @relation(fields: [entryId], references: [id])
  entryId   String
  filename  String
  mime      String
  size      Int
  path      String
  checksum  String?
  createdAt DateTime @default(now())
}

enum TagType {
  PROJECT
  GENERAL
}

model Tag {
  id          String          @id @default(uuid())
  name        String          @unique
  type        TagType         @default(GENERAL)
  color       String          @default("#6366f1")
  createdBy   String          @default("Admin")
  createdAt   DateTime        @default(now())
  assignments TagAssignment[]

  // New optional fields — existing tags unaffected (NULL by default)
  description String? // project overview / short description
  startDate   DateTime? // user-set display date, overrides createdAt for display
  members     ProjectMember[] // only populated for PROJECT-type tags

  // Project-capability fields (PROJECT-type tags only) — all additive, defaulted
  owner          String? // display owner; null for the General project
  isGeneral      Boolean  @default(false) // true for the single auto-seeded General project
  isPrivate      Boolean  @default(false)
  privateMembers String[] @default([]) // operators allowed to see a private project
  pinnedBy       String[] @default([]) // operators who have pinned this project (per-operator)

  // Short tag self-referential relation
  shortTagId    String? @unique
  shortTag      Tag?    @relation("ProjectShortTag", fields: [shortTagId], references: [id])
  parentProject Tag?    @relation("ProjectShortTag")
}

model TagAssignment {
  id         String   @id @default(cuid())
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType String // "RUN" | "ENTRY" | "INVENTORY" | "KNOWLEDGE_HUB"
  entityId   String
  assignedBy String
  assignedAt DateTime @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([tagId])
}

model ProtocolRun {
  id               String              @id @default(uuid())
  runId            String?             @unique
  title            String
  status           String              @default("IN_PROGRESS")
  locked           Boolean             @default(true)
  runBody          String
  notes            String              @default("")
  interactionState String              @default("{}")
  linkedInventory  String              @default("[]")
  operatorName     String              @default("")
  completedAt      DateTime?
  preRunNotes      String              @default("")
  abortNotes       String              @default("")
  isMockRun        Boolean             @default(false)
  requireStepOrder Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sourceEntry      Entry               @relation("RunSource", fields: [sourceEntryId], references: [id])
  sourceEntryId    String
  protocol         Protocol?           @relation(fields: [protocolId], references: [id])
  protocolId       String?
  runner           User?               @relation(fields: [runnerId], references: [id])
  runnerId         String?
  linkedEntries    Entry[]             @relation("RunLink")
  stepResults      StepResult[]
  stepFiles        RunStepFile[]
  inventoryUsage   RunInventoryUsage[]
}

model StepResult {
  id          String      @id @default(uuid())
  run         ProtocolRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId       String
  stepId      String // synthetic "step-{idx}" matching interactionState keys
  result      String // "PASSED" | "FAILED" | "SKIPPED"
  notes       String      @default("")
  fieldValues String      @default("{}") // JSON of field key→value
  completedAt DateTime    @default(now())

  @@unique([runId, stepId])
  @@index([runId])
}

model TodoHistory {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  date      String // YYYY-MM-DD — the day the list belonged to
  items     Json // TodoItem[] snapshot at time of cleanup
  createdAt DateTime @default(now())
}

model EquipmentBooking {
  id           String    @id @default(uuid())
  equipmentId  String
  operatorName String
  userId       String
  title        String    @default("")
  startTime    DateTime
  endTime      DateTime
  endedEarlyAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([equipmentId, startTime, endTime])
}

model Protocol {
  id               String   @id @default(uuid())
  entry            Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId          String   @unique
  name             String?
  technique        String?
  shortDescription String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sections ProtocolSection[]
  runs     ProtocolRun[]

  @@unique([name])
}

model ProtocolSection {
  id         String   @id @default(uuid())
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  protocolId String
  name       String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  steps ProtocolStep[]

  @@index([protocolId, order])
}

model ProtocolStep {
  id               String          @id @default(uuid())
  section          ProtocolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId        String
  stepType         StepType        @default(STEP)
  parentStep       ProtocolStep?   @relation("ProtocolStepToSubsteps", fields: [parentStepId], references: [id], onDelete: Cascade)
  parentStepId     String?
  substeps         ProtocolStep[]  @relation("ProtocolStepToSubsteps")
  estimatedMinutes Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([sectionId])
  @@index([parentStepId])
}

enum StepType {
  STEP
  SUBSTEP
}

model ProjectMember {
  id      String   @id @default(cuid())
  tagId   String
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([tagId, userId])
  @@index([tagId])
  @@index([userId])
}

model InventoryReagent {
  id                 String                @id @default(cuid())
  name               String
  category           String                @default("general")
  quantity           Float?
  initialQuantity    Float?
  unit               String?
  concentration      Float?
  concUnit           String?
  location           String?
  lotNumber          String?
  catalogNumber      String?
  vendor             String?
  expiryDate         DateTime?
  owner              String?
  notes              String?
  tags               String[]
  lowStockThreshold  Float?
  lowThresholdType   String? // "volume" | "mass"
  lowThresholdAmber  Float?
  lowThresholdRed    Float?
  useParentThreshold Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  researchNotes      ReagentResearchNote[]
  usageEvents        ReagentUsageEvent[]
  attachments        ReagentAttachment[]
  lots               ReagentLot[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy String?
  lastEditedAt DateTime?
}

model ReagentUsageEvent {
  id           String           @id @default(cuid())
  reagentId    String
  reagent      InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  reagentLotId String?
  reagentLot   ReagentLot?      @relation(fields: [reagentLotId], references: [id], onDelete: SetNull)
  amountUsed   Float
  usedBy       String
  date         DateTime         @default(now())
  notes        String?

  @@index([reagentId])
  @@index([reagentLotId])
}

model ReagentResearchNote {
  id        String           @id @default(cuid())
  reagentId String
  reagent   InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime         @default(now())

  @@index([reagentId])
}

model ReagentAttachment {
  id        String           @id @default(cuid())
  reagentId String
  reagent   InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  filename  String
  path      String
  mime      String
  size      Int
  createdAt DateTime         @default(now())

  @@index([reagentId])
}

model CellLine {
  id                 String                 @id @default(cuid())
  name               String
  species            String?
  tissue             String?
  morphology         String?
  passage            Int?
  location           String?
  owner              String?
  notes              String?
  tags               String[]
  useParentThreshold Boolean                @default(true)
  lowThresholdType   String?
  lowThresholdAmber  Float?
  lowThresholdRed    Float?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  researchNotes      CellLineResearchNote[]
  passages           CellLinePassage[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy String?
  lastEditedAt DateTime?
}

model CellLineResearchNote {
  id         String   @id @default(cuid())
  cellLineId String
  cellLine   CellLine @relation(fields: [cellLineId], references: [id], onDelete: Cascade)
  content    String
  author     String
  createdAt  DateTime @default(now())

  @@index([cellLineId])
}

model Plasmid {
  id                 String                @id @default(cuid())
  name               String
  backbone           String?
  insert             String?
  resistance         String?
  promoter           String?
  location           String?
  owner              String?
  notes              String?
  tags               String[]
  useParentThreshold Boolean               @default(true)
  lowThresholdType   String?
  lowThresholdAmber  Float?
  lowThresholdRed    Float?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  researchNotes      PlasmidResearchNote[]
  preps              PlasmidPrep[]
  proteinStocks      ProteinStock[]
  expressionUses     ExpressionPlasmid[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy String?
  lastEditedAt DateTime?
}

model PlasmidResearchNote {
  id        String   @id @default(cuid())
  plasmidId String
  plasmid   Plasmid  @relation(fields: [plasmidId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime @default(now())

  @@index([plasmidId])
}

model ProteinStock {
  id                 String                     @id @default(cuid())
  name               String
  plasmidId          String?
  plasmid            Plasmid?                   @relation(fields: [plasmidId], references: [id], onDelete: SetNull)
  concentration      Float?
  concUnit           String?
  volume             Float?
  volUnit            String?
  purity             String?
  location           String?
  owner              String?
  notes              String?
  tags               String[]
  useParentThreshold Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  researchNotes      ProteinStockResearchNote[]
  usageEvents        ProteinUsageEvent[]
  batches            ProteinBatch[]
  expressionTimeline ExpressionTimeline?

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy String?
  lastEditedAt DateTime?
}

model ProteinBatch {
  id                  String              @id @default(cuid())
  batchId             String              @unique
  stockId             String
  stock               ProteinStock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  purificationDate    DateTime
  initialVolume       Float // µL — immutable after creation
  currentVolume       Float // µL — managed via usage events
  concentration       Float? // mg/mL
  mw                  Float? // kDa
  extinctionCoeff     Float? // M⁻¹cm⁻¹
  a280                Float? // A280/260 ratio
  storageBuffer       String?
  storageLocationText String?
  lowThresholdType    String? // "volume" | "mass" | "percentage"
  lowThresholdAmber   Float?
  lowThresholdRed     Float?
  notes               String?
  volumeUnit          String?             @default("µL")
  createdBy           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  usageEvents         ProteinUsageEvent[]

  @@index([stockId])
}

model ProteinUsageEvent {
  id         String        @id @default(cuid())
  stockId    String
  stock      ProteinStock  @relation(fields: [stockId], references: [id], onDelete: Cascade)
  batchId    String?
  batch      ProteinBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  amountUsed Float
  usedBy     String
  date       DateTime      @default(now())
  notes      String?

  @@index([stockId])
  @@index([batchId])
}

model ProteinStockResearchNote {
  id        String       @id @default(cuid())
  stockId   String
  stock     ProteinStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime     @default(now())

  @@index([stockId])
}

model InventoryEditLog {
  id           String   @id @default(cuid())
  entityType   String // "REAGENT" | "CELL_LINE" | "PLASMID" | "PROTEIN_STOCK" | "PROTEIN_BATCH"
  entityId     String
  editedBy     String
  editedAt     DateTime @default(now())
  fieldName    String
  oldValue     String?
  newValue     String?
  warningShown Boolean  @default(false)

  @@index([entityType, entityId])
  @@index([editedBy])
  @@index([editedAt])
}

model DashboardNotification {
  id         String    @id @default(cuid())
  userId     String
  type       String    @default("ARCHIVE_REQUEST")
  entityType String
  entityId   String
  entityName String
  message    String
  fromUser   String
  note       String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  @@index([userId, isRead])
  @@index([userId])
  @@index([createdAt])
}

// ─── Batch / lot models ────────────────────────────────────────────────────────

model ReagentLot {
  id                String                @id @default(cuid())
  reagentId         String
  reagent           InventoryReagent      @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  lotNumber         String?
  quantity          Float
  unit              String
  supplier          String?
  catalogNumber     String?
  expiryDate        DateTime?
  receivedDate      DateTime?
  receivedBy        String?
  notes             String?
  lowThresholdType  String?
  lowThresholdAmber Float?
  lowThresholdRed   Float?
  attachments       InventoryAttachment[]
  usageEvents       ReagentUsageEvent[]
  isArchived        Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([reagentId])
}

model CellLinePassage {
  id                String                @id @default(cuid())
  cellLineId        String
  cellLine          CellLine              @relation(fields: [cellLineId], references: [id], onDelete: Cascade)
  passage           Int?
  vialCount         Int?
  freezeBackDate    DateTime?
  freezingSolution  String?
  frozenBy          String?
  storageLocation   String?
  notes             String?
  lowThresholdType  String?
  lowThresholdAmber Float?
  lowThresholdRed   Float?
  attachments       InventoryAttachment[]
  createdBy         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([cellLineId])
}

model PlasmidPrep {
  id                String                @id @default(cuid())
  plasmidId         String
  plasmid           Plasmid               @relation(fields: [plasmidId], references: [id], onDelete: Cascade)
  prepDate          DateTime?
  prepType          String?
  concentration     Float?
  volume            Float?
  preparedBy        String?
  sequenceVerified  Boolean               @default(false)
  notes             String?
  lowThresholdType  String?
  lowThresholdAmber Float?
  lowThresholdRed   Float?
  attachments       InventoryAttachment[]
  createdBy         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([plasmidId])
}

model InventoryAttachment {
  id                String           @id @default(cuid())
  filename          String
  path              String
  mime              String
  size              Int
  reagentLotId      String?
  reagentLot        ReagentLot?      @relation(fields: [reagentLotId], references: [id], onDelete: Cascade)
  cellLinePassageId String?
  cellLinePassage   CellLinePassage? @relation(fields: [cellLinePassageId], references: [id], onDelete: Cascade)
  plasmidPrepId     String?
  plasmidPrep       PlasmidPrep?     @relation(fields: [plasmidPrepId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@index([reagentLotId])
  @@index([cellLinePassageId])
  @@index([plasmidPrepId])
}

model Recipe {
  id          String            @id @default(cuid())
  name        String
  description String            @default("")
  notes       String            @default("")
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   User              @relation(fields: [createdById], references: [id])
  components  RecipeComponent[]
}

model RecipeComponent {
  id            String @id @default(cuid())
  recipeId      String
  reagentName   String
  concentration Float?
  unit          String @default("")
  notes         String @default("")
  order         Int    @default(0)
  inventoryId   String @default("")
  inventoryName String @default("")
  recipe        Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model ProtocolInventoryLink {
  id         String   @id @default(uuid())
  entryId    String
  entry      Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  itemType   String // "reagent" | "stock" | "plasmid" | "cellline"
  itemId     String
  itemName   String
  itemDetail String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())

  @@index([entryId])
}

model RunStepFile {
  id         String          @id @default(cuid())
  runId      String
  stepId     String // "step-0", "step-1" etc — matches StepResult stepId convention
  fileName   String // original filename shown to user
  fileKey    String // R2 object key (path in bucket)
  fileSize   Int // bytes
  mimeType   String
  uploadedBy String // userId
  notes      String          @default("")
  createdAt  DateTime        @default(now())
  run        ProtocolRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  uploader   User            @relation(fields: [uploadedBy], references: [id])
  annotation FileAnnotation?

  @@index([runId])
  @@index([runId, stepId])
}

// Actual inventory used in a run (run-time capture, source of truth). Distinct
// from ProtocolInventoryLink (author-time suggestions). itemName/itemDetail are
// snapshots so a later-deleted item still displays; itemId links back to the
// live inventory row for navigation. The [itemType,itemId] index powers the
// reverse lookup ("which runs used this item?"). See docs/CROSS_LINKING_DESIGN.md.
model RunInventoryUsage {
  id    String      @id @default(cuid())
  runId String
  run   ProtocolRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  itemType   String // reagent | stock | plasmid | cellline (matches /api/inventory/search + ProtocolInventoryLink)
  itemId     String // FK-by-convention to the inventory row (no hard FK: 4 possible tables)
  itemName   String // snapshot of the item name at capture time
  itemDetail String @default("") // snapshot (e.g. "50 µg/mL · Freezer B")

  lotId      String? // optional prep/batch/lot/passage id — reserved for lot-level traceability
  stepId     String? // optional "step-N" association — reserved for per-step capture
  amountUsed Float?
  unit       String?
  notes      String  @default("")

  addedBy   String   @default("")
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([itemType, itemId])
}

model LadderDefinition {
  id           String    @id @default(cuid())
  name         String
  manufacturer String
  bands        String // JSON array of numbers e.g. "[10,15,25,35,55,70,100,130,180]"
  createdAt    DateTime  @default(now())
  lanes        GelLane[]
}

model FileAnnotation {
  id            String             @id @default(cuid())
  runStepFileId String             @unique
  fileType      String // "SDS_PAGE" | "WESTERN_BLOT" | "CHROMATOGRAM" | "OTHER"
  notes         String             @default("")
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  runStepFile   RunStepFile        @relation(fields: [runStepFileId], references: [id], onDelete: Cascade)
  createdBy     User               @relation(fields: [createdById], references: [id])
  gelLanes      GelLane[]
  peaks         ChromatogramPeak[]
}

model GelLane {
  id            String            @id @default(cuid())
  annotationId  String
  laneNumber    Int
  ladderId      String?
  ladderName    String            @default("")
  contents      String            @default("")
  inventoryId   String            @default("")
  inventoryType String            @default("")
  inventoryName String            @default("")
  annotation    FileAnnotation    @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  ladder        LadderDefinition? @relation(fields: [ladderId], references: [id])
}

model ChromatogramPeak {
  id              String         @id @default(cuid())
  annotationId    String
  peakNumber      Int
  label           String         @default("")
  retentionVolume Float?
  inventoryId     String         @default("")
  inventoryType   String         @default("")
  inventoryName   String         @default("")
  annotation      FileAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
}

// ─── ExpiCHO transfection / expression run ───────────────────────────────────
// A special protocol type living under /protocols. One record per transfection,
// created from the calculator. Reagent math is captured as a snapshot so the
// checklist stays reproducible even if plasmid stocks change later. Scheduled
// actions (Day-1 enhancer/feed, Day-5 feed, harvest) are generated on create.
model ExpressionTimeline {
  id           String @id @default(cuid())
  name         String
  protocolType String @default("STANDARD") // STANDARD | HIGH_TITER | MAX_TITER
  status       String @default("IN_PROGRESS") // IN_PROGRESS | HARVESTED | CANCELLED

  // Volume / density snapshot
  cultureVolumeMl   Float
  volumeMode        String @default("FIXED") // FIXED | DILUTE | EXACT
  measuredDensityE6 Float?
  startingVolumeMl  Float?
  finalDnaConcUgMl  Float  @default(0.8)

  // Day-0 reagent snapshot (µg / µL), from calculateTransfection
  totalDnaUg           Float?
  totalDnaVolumeUl     Float?
  tubeVolumeUl         Float?
  optiproForDnaUl      Float?
  expifectamineUl      Float?
  optiproForExpifectUl Float?

  // Timeline anchors
  day0Date           DateTime
  harvestWindowStart DateTime?
  harvestWindowEnd   DateTime?
  harvestedAt        DateTime?

  runnerId  String?
  runner    User?    @relation(fields: [runnerId], references: [id], onDelete: SetNull)
  createdBy String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     String   @default("")

  // Optional link to the protein produced by this run
  proteinStockId String?       @unique
  proteinStock   ProteinStock? @relation(fields: [proteinStockId], references: [id], onDelete: SetNull)

  plasmids ExpressionPlasmid[]
  actions  ExpressionAction[]

  @@index([status])
  @@index([day0Date])
}

model ExpressionPlasmid {
  id         String             @id @default(cuid())
  timelineId String
  timeline   ExpressionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  plasmidId  String?
  plasmid    Plasmid?           @relation(fields: [plasmidId], references: [id], onDelete: SetNull)

  name          String // snapshot of plasmid name at transfection time
  stockConcNgUl Float
  ratio         Float
  amountUg      Float
  volumeUl      Float
  order         Int    @default(0)

  @@index([timelineId])
}

model ExpressionAction {
  id         String             @id @default(cuid())
  timelineId String
  timeline   ExpressionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  type          String // ENHANCER | FEED | FEED2 | TEMP_SHIFT | HARVEST
  label         String
  dayOffset     Int // days after day 0
  scheduledDate DateTime
  detail        String    @default("")
  done          Boolean   @default(false)
  doneAt        DateTime?
  doneBy        String?

  @@index([timelineId])
  @@index([scheduledDate, done])
}
