generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  name               String?
  role               String          @default("MEMBER")
  createdAt          DateTime        @default(now())
  entries            Entry[]
  protocolRuns       ProtocolRun[]
  projectMemberships ProjectMember[]
}

enum EntryType {
  GENERAL
  EXPERIMENT
  PROTOCOL
  NOTE
  CELL_LINE
  PROTEIN
  REAGENT
  CHROMATOGRAPHY_RUN
}

model Entry {
  id           String        @id @default(uuid())
  title        String
  description  String        @default("")
  technique    String        @default("General")
  entryType    EntryType     @default(GENERAL)
  typedData    Json          @default("{}")
  body         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  version      Int           @default(1)
  author       User?         @relation(fields: [authorId], references: [id])
  authorId     String?
  attachments   Attachment[]
  protocolRuns  ProtocolRun[]  @relation("RunSource")
  linkedRun     ProtocolRun?   @relation("RunLink", fields: [linkedRunId], references: [id])
  linkedRunId   String?
  protocol      Protocol?
}

model Attachment {
  id        String   @id @default(uuid())
  entry     Entry    @relation(fields: [entryId], references: [id])
  entryId   String
  filename  String
  mime      String
  size      Int
  path      String
  checksum  String?
  createdAt DateTime @default(now())
}

enum TagType {
  PROJECT
  GENERAL
}

model Tag {
  id          String          @id @default(uuid())
  name        String          @unique
  type        TagType         @default(GENERAL)
  color       String          @default("#6366f1")
  createdBy   String          @default("Admin")
  createdAt   DateTime        @default(now())
  assignments TagAssignment[]

  // New optional fields — existing tags unaffected (NULL by default)
  description String?         // project overview / short description
  startDate   DateTime?       // user-set display date, overrides createdAt for display
  members     ProjectMember[] // only populated for PROJECT-type tags
}

model TagAssignment {
  id         String   @id @default(cuid())
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType String   // "RUN" | "ENTRY" | "INVENTORY" | "KNOWLEDGE_HUB"
  entityId   String
  assignedBy String
  assignedAt DateTime @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([tagId])
}

model ProtocolRun {
  id               String    @id @default(uuid())
  runId            String?   @unique
  title            String
  status           String    @default("IN_PROGRESS")
  locked           Boolean   @default(true)
  runBody          String
  notes            String    @default("")
  interactionState String    @default("{}")
  operatorName     String    @default("")
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sourceEntry    Entry     @relation("RunSource", fields: [sourceEntryId], references: [id])
  sourceEntryId  String
  protocol       Protocol? @relation(fields: [protocolId], references: [id])
  protocolId     String?
  runner         User?     @relation(fields: [runnerId], references: [id])
  runnerId       String?
  linkedEntries  Entry[]   @relation("RunLink")
  stepResults    StepResult[]
}

model StepResult {
  id          String      @id @default(uuid())
  run         ProtocolRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId       String
  stepId      String      // synthetic "step-{idx}" matching interactionState keys
  result      String      // "PASSED" | "FAILED" | "SKIPPED"
  notes       String      @default("")
  fieldValues String      @default("{}") // JSON of field key→value
  completedAt DateTime    @default(now())

  @@unique([runId, stepId])
  @@index([runId])
}

model TodoHistory {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  date      String   // YYYY-MM-DD — the day the list belonged to
  items     Json     // TodoItem[] snapshot at time of cleanup
  createdAt DateTime @default(now())
}

model EquipmentBooking {
  id            String    @id @default(uuid())
  equipmentId   String
  operatorName  String
  userId        String
  title         String    @default("")
  startTime     DateTime
  endTime       DateTime
  endedEarlyAt  DateTime?
  createdAt     DateTime  @default(now())

  @@index([equipmentId, startTime, endTime])
}

model Protocol {
  id               String   @id @default(uuid())
  entry            Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId          String   @unique
  name             String?
  technique        String?
  shortDescription String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sections ProtocolSection[]
  runs     ProtocolRun[]

  @@unique([name])
}

model ProtocolSection {
  id         String   @id @default(uuid())
  protocol   Protocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  protocolId String
  name       String
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  steps ProtocolStep[]

  @@index([protocolId, order])
}

model ProtocolStep {
  id         String          @id @default(uuid())
  section    ProtocolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId  String
  stepType   StepType        @default(STEP)
  parentStep ProtocolStep?   @relation("ProtocolStepToSubsteps", fields: [parentStepId], references: [id], onDelete: Cascade)
  parentStepId String?
  substeps   ProtocolStep[]  @relation("ProtocolStepToSubsteps")
  estimatedMinutes Int?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([sectionId])
  @@index([parentStepId])
}

enum StepType {
  STEP
  SUBSTEP
}

model ProjectMember {
  id      String   @id @default(cuid())
  tagId   String
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([tagId, userId])
  @@index([tagId])
  @@index([userId])
}
model InventoryReagent {
  id                String               @id @default(cuid())
  name              String
  category          String               @default("general")
  quantity          Float?
  initialQuantity   Float?
  unit              String?
  concentration     Float?
  concUnit          String?
  location          String?
  lotNumber         String?
  catalogNumber     String?
  vendor            String?
  expiryDate        DateTime?
  owner             String?
  notes             String?
  tags              String[]
  lowStockThreshold Float?
  lowThresholdType  String?              // "volume" | "mass"
  lowThresholdAmber Float?
  lowThresholdRed   Float?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  researchNotes     ReagentResearchNote[]
  usageEvents       ReagentUsageEvent[]
  attachments       ReagentAttachment[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy  String?
  lastEditedAt  DateTime?
}

model ReagentUsageEvent {
  id         String           @id @default(cuid())
  reagentId  String
  reagent    InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  amountUsed Float
  usedBy     String
  date       DateTime         @default(now())
  notes      String?

  @@index([reagentId])
}

model ReagentResearchNote {
  id        String           @id @default(cuid())
  reagentId String
  reagent   InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime         @default(now())

  @@index([reagentId])
}

model ReagentAttachment {
  id        String           @id @default(cuid())
  reagentId String
  reagent   InventoryReagent @relation(fields: [reagentId], references: [id], onDelete: Cascade)
  filename  String
  path      String
  mime      String
  size      Int
  createdAt DateTime         @default(now())

  @@index([reagentId])
}

model CellLine {
  id            String                 @id @default(cuid())
  name          String
  species       String?
  tissue        String?
  morphology    String?
  passage       Int?
  location      String?
  owner         String?
  notes         String?
  tags          String[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  researchNotes CellLineResearchNote[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy  String?
  lastEditedAt  DateTime?
}

model CellLineResearchNote {
  id         String   @id @default(cuid())
  cellLineId String
  cellLine   CellLine @relation(fields: [cellLineId], references: [id], onDelete: Cascade)
  content    String
  author     String
  createdAt  DateTime @default(now())

  @@index([cellLineId])
}

model Plasmid {
  id            String                @id @default(cuid())
  name          String
  backbone      String?
  insert        String?
  resistance    String?
  promoter      String?
  location      String?
  owner         String?
  notes         String?
  tags          String[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  researchNotes PlasmidResearchNote[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy  String?
  lastEditedAt  DateTime?
}

model PlasmidResearchNote {
  id        String   @id @default(cuid())
  plasmidId String
  plasmid   Plasmid  @relation(fields: [plasmidId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime @default(now())

  @@index([plasmidId])
}

model ProteinStock {
  id            String                   @id @default(cuid())
  name          String
  concentration Float?
  concUnit      String?
  volume        Float?
  volUnit       String?
  purity        String?
  location      String?
  owner         String?
  notes         String?
  tags          String[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  researchNotes ProteinStockResearchNote[]
  usageEvents   ProteinUsageEvent[]
  batches       ProteinBatch[]

  // Archive fields
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  archivedBy       String?
  archiveReason    String?
  markedForArchive Boolean   @default(false)
  markedBy         String?
  markedNote       String?
  markedAt         DateTime?

  // Edit tracking
  lastEditedBy  String?
  lastEditedAt  DateTime?
}

model ProteinBatch {
  id                  String       @id @default(cuid())
  batchId             String       @unique
  stockId             String
  stock               ProteinStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  purificationDate    DateTime
  initialVolume       Float        // µL — immutable after creation
  currentVolume       Float        // µL — managed via usage events
  concentration       Float?       // mg/mL
  mw                  Float?       // kDa
  extinctionCoeff     Float?       // M⁻¹cm⁻¹
  a280                Float?       // A280/260 ratio
  storageBuffer       String?
  storageLocationText String?
  lowThresholdType    String?      // "volume" | "mass" | "percentage"
  lowThresholdAmber   Float?
  lowThresholdRed     Float?
  notes               String?
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([stockId])
}

model ProteinUsageEvent {
  id         String       @id @default(cuid())
  stockId    String
  stock      ProteinStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  amountUsed Float
  usedBy     String
  date       DateTime     @default(now())
  notes      String?

  @@index([stockId])
}

model ProteinStockResearchNote {
  id        String       @id @default(cuid())
  stockId   String
  stock     ProteinStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime     @default(now())

  @@index([stockId])
}

model InventoryEditLog {
  id           String   @id @default(cuid())
  entityType   String   // "REAGENT" | "CELL_LINE" | "PLASMID" | "PROTEIN_STOCK" | "PROTEIN_BATCH"
  entityId     String
  editedBy     String
  editedAt     DateTime @default(now())
  fieldName    String
  oldValue     String?
  newValue     String?
  warningShown Boolean  @default(false)

  @@index([entityType, entityId])
  @@index([editedBy])
  @@index([editedAt])
}

model DashboardNotification {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("ARCHIVE_REQUEST")
  entityType  String
  entityId    String
  entityName  String
  message     String
  fromUser    String
  note        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([userId, isRead])
  @@index([userId])
  @@index([createdAt])
}
